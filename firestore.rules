
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SΡ±naq m…ôrh…ôl…ôsind…ô olduΡüumuz ΟΦΟßΟΦn bΟΦtΟΦn bazaya tam oxuma v…ô yazma icaz…ôsi verilir.
    // Bu, h…ôm daxil olan, h…ôm d…ô anonim istifad…ôΟßil…ôr ΟΦΟßΟΦn keΟß…ôrlidir.
    match /{document=**} {
      allow read, write: if true;
    }

    // Τèsas kolleksiyalar ΟΦΟßΟΦn a≈ükar icaz…ôl…ôr (Redeploy trigger)
    match /exams/{examId} {
      allow read, write: if true;
    }
    match /studentAttempts/{attemptId} {
      allow read, write: if true;
    }
    match /appeals/{appealId} {
      allow read, write: if true;
    }
    match /accessCodes/{codeId} {
      allow read, write: if true;
    }
  }
}
