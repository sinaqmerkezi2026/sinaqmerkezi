
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- TEST RULES ---
    match /test_messages/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    match /exams/{examId} {
      allow get: if true; // Allow students to read exam details if they have the ID
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      match /questions/{questionId} {
        allow get, list: if isSignedIn(); // Students need to read questions
        allow create, update, delete: if isAdmin();

        match /multipleChoiceOptions/{optionId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isAdmin();
        }
        
        match /openEndedCorrectAnswer/{id} {
          allow get, list: if isAdmin();
          allow create, update, delete: if isAdmin();
        }

        match /explanationQuestionCriteria/{id} {
          allow get, list: if isAdmin();
          allow create, update, delete: if isAdmin();
        }
      }

      match /accessCodes/{accessCodeId} {
        allow get: if isSignedIn();
        // Allow list via collection group for code lookup
        allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 1);
        allow update: if isSignedIn() && resource.data.isUsedForEntry == false;
        allow create, delete: if isAdmin();
      }
    }

    match /studentAttempts/{studentAttemptId} {
      function isStudentOwner(data) {
        return isSignedIn() && (data.studentAuthUid == request.auth.uid || data.studentAuthUid == 'anon');
      }
      
      allow get, list: if isAdmin() || isStudentOwner(resource.data);
      allow create: if isSignedIn();
      allow update: if isAdmin() || isStudentOwner(resource.data);
      allow delete: if isAdmin();

      match /studentAnswers/{studentAnswerId} {
        allow get, list: if isAdmin() || isSignedIn();
        allow create: if isSignedIn();
        allow update: if isAdmin() || isSignedIn();
        allow delete: if isAdmin();
      }
    }
  }
}
