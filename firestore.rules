
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- TEST RULES ---
    match /test_messages/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    match /exams/{examId} {
      // İmtahanların siyahısını və detallarını hamı görə bilsin
      allow get, list: if true; 
      allow create, update, delete: if isAdmin() || isSignedIn(); // İnkişaf mərhələsi üçün daxil olanlara icazə veririk

      match /questions/{questionId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin() || isSignedIn();

        match /multipleChoiceOptions/{optionId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isAdmin() || isSignedIn();
        }
        
        match /openEndedCorrectAnswer/{id} {
          allow get, list: if isAdmin() || isSignedIn();
          allow create, update, delete: if isAdmin() || isSignedIn();
        }

        match /explanationQuestionCriteria/{id} {
          allow get, list: if isAdmin() || isSignedIn();
          allow create, update, delete: if isAdmin() || isSignedIn();
        }
      }

      match /accessCodes/{accessCodeId} {
        allow get: if isSignedIn();
        allow list: if isAdmin() || isSignedIn();
        allow update: if isSignedIn();
        allow create, delete: if isAdmin() || isSignedIn();
      }
    }

    // Collection Group qaydası: Tələbə girişi zamanı kodların axtarılması üçün
    match /{path=**}/accessCodes/{accessCodeId} {
      allow read: if isSignedIn() || true;
    }

    match /studentAttempts/{studentAttemptId} {
      function isStudentOwner(data) {
        return isSignedIn() && (data.studentAuthUid == request.auth.uid || data.studentAuthUid == 'anon');
      }
      
      allow get, list: if isAdmin() || isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isSignedIn();
      allow delete: if isAdmin() || isSignedIn();

      match /studentAnswers/{studentAnswerId} {
        allow get, list: if isAdmin() || isSignedIn();
        allow create: if isSignedIn();
        allow update: if isAdmin() || isSignedIn();
        allow delete: if isAdmin() || isSignedIn();
      }
    }
  }
}
