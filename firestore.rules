rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Redeyploy t톛tiyi 칲칞칲n vaxt m칬h칲r칲: 2024-05-21 21:00
    // He칞 bir autentifikasiya t톛l톛b olunmadan b칲t칲n bazaya tam oxuma v톛 yazma icaz톛si verilir.
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}