
//re
{
  "entities": {
    "Exam": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exam",
      "type": "object",
      "description": "Represents an online examination configured by an admin.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "activeStartDate": { "type": "string", "format": "date-time" },
        "activeEndDate": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" }
      },
      "required": ["id", "name", "activeStartDate", "activeEndDate", "durationMinutes", "price"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "Custom categories for exams.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Question": {
      "title": "Question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "type": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "order": { "type": "number" }
      },
      "required": ["id", "examId", "type", "text", "order"]
    },
    "Appeal": {
      "title": "Appeal",
      "type": "object",
      "description": "Student appeal for a specific question result.",
      "properties": {
        "id": { "type": "string" },
        "attemptId": { "type": "string" },
        "questionId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentReason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "adminComment": { "type": "string" },
        "awardedScore": { "type": "number" },
        "createdAt": { "type": "number" },
        "processedAt": { "type": "number" }
      },
      "required": ["id", "attemptId", "questionId", "studentReason", "status", "createdAt"]
    },
    "PromoCode": {
      "title": "PromoCode",
      "type": "object",
      "description": "A discount code generated for students based on performance.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountPercent": { "type": "number" },
        "attemptId": { "type": "string" },
        "studentName": { "type": "string" },
        "isUsed": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "code", "discountPercent", "attemptId", "isUsed", "isActive"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "structure": [
      {
        "path": "exams/{examId}",
        "definition": {
          "entityName": "Exam",
          "schema": { "$ref": "#/backend/entities/Exam" },
          "description": "Master exam definitions."
        }
      },
      {
        "path": "categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": { "$ref": "#/backend/entities/Category" },
          "description": "Exam categories managed by admin."
        }
      },
      {
        "path": "studentAttempts/{studentAttemptId}",
        "definition": {
          "entityName": "StudentAttempt",
          "description": "Student's exam attempt data."
        }
      },
      {
        "path": "appeals/{appealId}",
        "definition": {
          "entityName": "Appeal",
          "schema": { "$ref": "#/backend/entities/Appeal" },
          "description": "Student appeals for question results."
        }
      },
      {
        "path": "promoCodes/{promoCodeId}",
        "definition": {
          "entityName": "PromoCode",
          "schema": { "$ref": "#/backend/entities/PromoCode" },
          "description": "Discount codes for students."
        }
      }
